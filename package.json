{
  "name": "pc-monitor",
  "version": "1.0.0",
  "description": "Monitor de hardware do PC em tempo real — CPU, GPU, RAM, disco e rede",
  "main": "main.js",
  "author": {
    "name": "Rony Drop",
    "url": "https://github.com/ronydrop"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.rony.pc-monitor",
    "productName": "PC Monitor",
    "files": [
      "main.js",
      "index.html",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "signingHashAlgorithms": null
    },
    "portable": {
      "artifactName": "PCMonitor-portable.exe"
    },
    "nsis": {
      "artifactName": "PCMonitor-Setup-${version}.exe",
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PC Monitor"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "systeminformation": "^5.31.1"
  }
}
